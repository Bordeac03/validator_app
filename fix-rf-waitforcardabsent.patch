-        // Release shared hardware handles so we never leak them. (RF uses
-        // open-per-read and always closes in its own finally block, so there is
-        // no lingering RF handle to release here.)
+        // Release shared hardware handles so we never leak them.
         releaseScannerService()
+        recycleRfDevice()
         io.shutdownNow()
     }
 

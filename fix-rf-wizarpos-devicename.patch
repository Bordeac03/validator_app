     WidgetsBinding.instance.addPostFrameCallback((_) async {
       _caps = await _hw.capabilities();
       await _hw.startKiosk(); // no-op unless provisioned as device owner
+      _diag = await _hw.nfcDiag(); // surface RF init status on screen
       if (mounted) setState(() {});
       _startLoop();
     });
@@ -121,6 +123,10 @@ class _ValidatorScreenState extends State<ValidatorScreen>
           );
           continue;
         }
+        // Refresh the on-screen diagnostic so we can see why RF isn't firing
